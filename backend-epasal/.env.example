# ===========================================
# Environment
# ===========================================
NODE_ENV=production
PORT=4000

# ===========================================
# Database
# ===========================================
MONGODB_URI=mongodb://user:pass@127.0.0.1:27017/dbname?authSource=dbname

# ===========================================
# JWT secrets (set strong, unique values)
# ===========================================
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ADMIN_SECRET=
JWT_ADMIN_REFRESH_SECRET=
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Secret for short-lived MFA "pending" tokens issued between the credential
# check and the TOTP/backup-code challenge (5m expiry). Must differ from the
# JWT secrets above.
MFA_PENDING_SECRET=

# ===========================================
# Field-level encryption at rest (AES-256-GCM)
# ===========================================
# Master key for encrypting PII (phone numbers, addresses) before they hit
# MongoDB. 32 bytes, hex-encoded (64 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Use a DIFFERENT key per environment. Never commit a real value here.
ENCRYPTION_KEY=<generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
# Bump this and move the old value to ENCRYPTION_KEY_V0 when rotating keys.
ENCRYPTION_KEY_VERSION=1
# Previous key, kept only during a rotation migration (see
# scripts/rotate-encryption-key.ts). Leave empty otherwise.
ENCRYPTION_KEY_V0=

# Google Sign-In — OAuth 2.0 Client ID from Google Cloud Console
# (APIs & Services > Credentials). Must match VITE_GOOGLE_CLIENT_ID on the
# frontend; no client secret needed since we only verify ID tokens.
GOOGLE_CLIENT_ID=

# ===========================================
# hCaptcha (brute-force protection on login/register)
# ===========================================
# Secret key from https://dashboard.hcaptcha.com — PRIVATE, backend only.
# Never expose this in frontend code or a VITE_ prefixed variable.
HCAPTCHA_SECRET_KEY=
HCAPTCHA_VERIFY_URL=https://hcaptcha.com/siteverify
# Random string that lets Jest/integration tests bypass real CAPTCHA
# verification via the `x-captcha-bypass` header. Leave unset in production.
CAPTCHA_BYPASS_KEY=

# ===========================================
# Cloudinary (image uploads)
# ===========================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===========================================
# CORS / cookies / API
# ===========================================
# Comma-separated list of allowed origins
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
COOKIE_SAMESITE=none
API_BASE=https://api.yourdomain.com/api/v1
# Leading-dot domain to share the refresh-token cookie across subdomains in
# production (e.g. ".epasaley.com"). Leave unset in development.
COOKIE_DOMAIN=

# ===========================================
# Session management
# ===========================================
# Max concurrent active refresh-token sessions per account — the oldest is
# revoked once a new login would exceed this.
MAX_SESSIONS_PER_USER=3
# Off by default: device fingerprints (UA + Accept-Language + Accept-Encoding)
# change legitimately across VPNs/browser updates, so this only flags a
# mismatch (SUSPICIOUS_ACTIVITY audit log + deviceMismatch flag) rather than
# blocking the refresh. Set to true to demo it.
ENABLE_DEVICE_BINDING=false
