{
  "name": "epasaley-backend",
  "version": "1.0.0",
  "description": "Scalable e-commerce backend with Node.js, Express, TypeScript, MongoDB",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "npm run build",
    "prestart": "npm run build",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest --runInBand --detectOpenHandles",
    "build": "tsc",
    "seed": "ts-node src/seed.ts",
    "setup-admin": "ts-node src/seed.ts",
    "seed:data": "ts-node --transpile-only src/seed-data.ts",
    "seed:fashion": "ts-node --transpile-only src/seed-fashion.ts",
    "seed:fashion:bulk": "ts-node --transpile-only src/seed-fashion-bulk.ts",
    "seed:fashion:catalog": "node seedProducts.js",
    "gen:admin-token": "node scripts/generate_admin_token.js",
    "gen:admin-token:save": "node scripts/generate_admin_token.js --save",
    "smoke": "node scripts/smoke_tests.js",
    "start": "node -r dotenv/config dist/server.js",
    "start:cluster": "node dist/server.js --cluster",
    "diagnose": "ts-node --transpile-only scripts/diagnose.ts",
    "reset:db": "ts-node --transpile-only scripts/reset-db.ts",
    "rotate:encryption-key": "ts-node --transpile-only scripts/rotate-encryption-key.ts",
    "diagnose:sale": "ts-node --transpile-only scripts/diagnose-sale.ts",
    "diagnose:coupon": "ts-node --transpile-only scripts/diagnose-coupon.ts"
  },
  "keywords": [
    "ecommerce",
    "backend",
    "typescript",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.8.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.9.0",
    "helmet": "^7.2.0",
    "hpp": "^0.2.3",
    "jest": "^30.2.0",
    "joi": "^17.11.0",
    "joi-to-swagger": "^6.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.6.3",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-mongo-sanitize": "^1.3.2",
    "@types/hpp": "^0.2.7",
    "@types/jest": "^29.5.5",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^2.0.16",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "@types/zxcvbn": "^4.4.5",
    "mongodb-memory-server": "^10.3.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
