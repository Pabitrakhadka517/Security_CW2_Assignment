# ============================================================
# Environment Variables — copy this file to .env
# Only ONE variable controls the backend URL: VITE_API_BASE_URL
# All API calls in the app read from src/config/index.js
# which reads from this variable.
# Backend base URL (no trailing slash) — config appends /api/v1.
# ============================================================

VITE_API_BASE_URL=https://api.yourdomain.com
VITE_APP_NAME=Epasaley
VITE_APP_DESCRIPTION=Nepal's Trusted Online Store

# Google Sign-In OAuth Client ID (must match backend's GOOGLE_CLIENT_ID).
# Create one at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# hCaptcha site key (public, safe to expose in frontend code — the secret key
# stays backend-only). Get one at https://dashboard.hcaptcha.com
VITE_HCAPTCHA_SITE_KEY=
